rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isAuthenticated() && getUserData().role == role;
    }

    // Users Collection rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }

    // Projects Collection rules
    match /projects/{projectId} {
      allow read: if isAuthenticated();
      
      // Only authenticated clients can create a project
      allow create: if isAuthenticated() && hasRole('client');
      
      // Allow update if client owner OR assigned freelancer
      allow update: if isAuthenticated() && (
        resource.data.clientId == request.auth.uid || 
        resource.data.assignedFreelancerId == request.auth.uid
      );
      
      // Only client owner can delete project
      allow delete: if isAuthenticated() && resource.data.clientId == request.auth.uid;
    }

    // Bids/Proposals Collection rules
    match /bids/{bidId} {
      allow read: if isAuthenticated();
      
      // Only freelancers can submit a bid
      allow create: if isAuthenticated() && hasRole('freelancer');
      
      // Allow update: 
      // - Freelancer can modify/cancel their own bid
      // - Client (owner of the project) can update status (accept/reject)
      allow update: if isAuthenticated() && (
        resource.data.freelancerId == request.auth.uid || 
        resource.data.clientId == request.auth.uid
      );
      
      // Only freelancer can delete their bid
      allow delete: if isAuthenticated() && resource.data.freelancerId == request.auth.uid;
    }
  }
}
